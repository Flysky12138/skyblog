{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "es2022",
    "lib": ["DOM", "ESNext"],

    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,

    "strict": true,
    "noUncheckedIndexedAccess": false,

    "esModuleInterop": true,
    "isolatedModules": true,

    "skipLibCheck": true,

    "noEmit": true
  }
}
