model VisitorInfo {
  id            String   @id @default(uuid(7))
  createdAt     DateTime @default(now())
  ip            String
  city          String?
  country       String?
  countryRegion String?
  latitude      String?
  longitude     String?
  agent         String?
  referer       String?
  clashs        Clash[]

  @@map("visitor_infos")
}
