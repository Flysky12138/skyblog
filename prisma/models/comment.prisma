model Comment {
  id        String   @id @default(uuid(7))
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  content      String
  isDeleted    Boolean @default(false) @map("is_deleted")
  commentCount Int     @default(0) @map("comment_count") // 直接回复数

  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String? @map("author_id")
  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentToComment", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentToComment")

  activityLogId BigInt?      @map("activity_log_id")
  activityLog   ActivityLog? @relation(fields: [activityLogId], references: [id], onDelete: SetNull)

  @@index([isDeleted])
  @@index([authorId])
  @@index([activityLogId])
  @@index([parentId, createdAt(sort: Desc)])
  @@index([postId, parentId, createdAt(sort: Desc)])
  @@map("comments")
}
