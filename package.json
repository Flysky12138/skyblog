{
  "name": "skyblog",
  "version": "0.1.0",
  "private": true,
  "author": "xhp443@gmail.com",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:type": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky",
    "predev": "npm run script:api:runtime nodejs && npm run db:dev:gen && npm run script:api:type",
    "prebuild": "npm run script:api:runtime edge && npm run db:prod:gen && npm run script:api:type",
    "db:dev:gen": "prisma generate --no-hints --schema prisma/sqlite",
    "db:dev:push": "prisma db push --schema prisma/sqlite",
    "db:dev:studio": "prisma studio --schema prisma/sqlite",
    "db:prod:gen": "prisma generate --no-hints --schema prisma/psql",
    "db:prod:push": "dotenv -e .env.local -- prisma db push --schema prisma/psql",
    "script:api:type": "tsx scripts/generator-api-type.ts",
    "script:api:runtime": "tsx scripts/api-runtime.ts",
    "wrangler:deploy": "wrangler deploy",
    "wrangler:secret": "wrangler secret put AUTH_KEY_SECRET",
    "wrangler:create-bucket": "wrangler r2 bucket create skyblog",
    "vercel:env-pull": "vercel env pull"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,css,json,yaml}": "prettier --write",
    "*.prisma": "prisma format --schema"
  },
  "dependencies": {
    "@emotion/cache": "^11.13.1",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@lottielab/lottie-player": "^1.0.3",
    "@mdx-js/loader": "^3.0.1",
    "@mdx-js/react": "^3.0.1",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.16.6",
    "@mui/joy": "5.0.0-beta.48",
    "@mui/lab": "5.0.0-alpha.172",
    "@mui/material": "^5.16.6",
    "@neondatabase/serverless": "^0.9.4",
    "@next/mdx": "^14.2.5",
    "@octokit/rest": "^21.0.1",
    "@prisma/adapter-neon": "^5.17.0",
    "@prisma/client": "^5.17.0",
    "@rehype-pretty/transformers": "^0.13.2",
    "@vercel/analytics": "^1.3.1",
    "@vercel/blob": "^0.23.4",
