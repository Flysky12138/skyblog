{
  "name": "skyblog",
  "version": "0.1.0",
  "private": true,
  "author": "xhp443@gmail.com",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:type": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky install",
    "cz": "cz",
    "predev": "prisma generate --schema prisma/sqlite.prisma",
    "prebuild": "prisma generate --schema prisma/psql.prisma",
    "db:dev:push": "prisma db push --schema prisma/sqlite.prisma",
    "db:dev:studio": "prisma studio --schema prisma/sqlite.prisma",
    "db:prod:push": "dotenv -e .env.local -- prisma db push --schema prisma/psql.prisma"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,css,scss,json,yaml}": "prettier --write",
    "*.prisma": "prisma format --schema"
  },
  "dependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@mdx-js/loader": "^2.3.0",
    "@mdx-js/react": "^2.3.0",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.11",
    "@mui/joy": "5.0.0-beta.29",
    "@mui/lab": "5.0.0-alpha.166",
    "@mui/material": "^5.15.11",
    "@next/mdx": "^14.1.0",
    "@prisma/client": "^5.10.2",
    "@vercel/blob": "^0.18.0",
    "@vercel/edge": "^1.1.1",
    "@vercel/edge-config": "^0.4.1",
    "@vercel/kv": "^1.0.1",
    "client-only": "^0.0.1",
    "clsx": "^2.1.0",
    "dayjs": "^1.11.10",
    "framer-motion": "9.0.2",
    "immer": "^10.0.3",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.45.0",
    "next": "^14.1.0",
    "next-auth": "5.0.0-beta.5",
    "next-mdx-remote": "^4.4.1",
    "nextjs-toploader": "^1.6.6",
    "puppeteer-core": "21.3.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-photo-view": "^1.2.4",
    "react-use": "^17.5.0",
    "react-window": "^1.8.10",
    "rehype-katex": "^7.0.0",
    "rehype-prism-plus": "^1.6.3",
    "rehype-slug": "^6.0.0",
    "remark-directive": "2.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-gfm": "3.0.1",
    "remark-math": "5.1.1",
    "server-only": "^0.0.1",
    "sonner": "^1.4.3",
    "swr": "^2.2.5",
    "unist-util-visit": "^5.0.0",
    "use-immer": "^0.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.8.1",
    "@commitlint/config-conventional": "^17.8.1",
    "@konghayao/cn-font-split": "^4.11.2",
    "@tailwindcss/typography": "^0.5.10",
    "@types/mdast": "^4.0.3",
    "@types/mdx": "^2.0.11",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.17",
    "commitizen": "^4.3.0",
    "cz-git": "^1.8.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-sort-keys-plus": "^1.4.0",
    "eslint-plugin-typescript-sort-keys": "^3.2.0",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "prisma": "^5.10.2",
    "sass": "^1.71.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
