    "husky": "^9.1.4",
    "lint-staged": "^15.2.7",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "6.5.2",
    "postcss": "^8.4.40",
    "postcss-nesting": "^12.1.5",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.0.0",
    "prettier-plugin-tailwindcss": "^0.6.5",
    "prisma": "^5.17.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.7",
    "tsx": "^4.16.5",
    "typescript": "^5.5.4",
    "typescript-eslint": "^7.18.0",
    "wrangler": "^3.68.0"
  },
  "commitlint": {
