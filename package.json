{
  "name": "skyblog",
  "version": "0.1.0",
  "private": true,
  "author": "xhp443@gmail.com",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:type": "tsc --noEmit",
    "format": "prettier --write .",
    "cz": "cz",
    "prepare": "husky",
    "predev": "prisma generate --schema prisma/sqlite",
    "prebuild": "prisma generate --no-engine --schema prisma/psql",
    "db:dev:push": "prisma db push --schema prisma/sqlite",
    "db:dev:studio": "prisma studio --schema prisma/sqlite",
    "db:prod:push": "dotenv -e .env.local -- prisma db push --schema prisma/psql"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{md,css,json,yaml}": "prettier --write",
    "*.prisma.": "prisma format --schema"
  },
  "dependencies": {
    "@emotion/cache": "^11.11.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@lottielab/lottie-player": "^1.0.3",
    "@mdx-js/loader": "^2.3.0",
    "@mdx-js/react": "^2.3.0",
    "@monaco-editor/react": "^4.6.0",
    "@mui/icons-material": "^5.15.19",
    "@mui/joy": "5.0.0-beta.36",
    "@mui/lab": "5.0.0-alpha.170",
    "@mui/material": "^5.15.19",
    "@next/mdx": "^14.2.3",
    "@prisma/client": "^5.15.0",
    "@prisma/extension-accelerate": "^1.1.0",
    "@vercel/analytics": "^1.3.1",
    "@vercel/blob": "^0.18.0",
    "@vercel/edge": "^1.1.1",
    "@vercel/edge-config": "^0.4.1",
    "@vercel/kv": "^1.0.1",
    "@vercel/speed-insights": "^1.0.11",
    "client-only": "^0.0.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.11",
    "framer-motion": "9.0.2",
    "immer": "^10.1.1",
    "jszip": "^3.10.1",
    "monaco-editor": "^0.45.0",
    "next": "^14.2.3",
    "next-auth": "5.0.0-beta.5",
    "next-mdx-remote": "^4.4.1",
    "nextjs-toploader": "^1.6.12",
    "puppeteer-core": "21.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-photo-view": "^1.2.4",
    "react-use": "^17.5.0",
    "react-window": "^1.8.10",
    "rehype-katex": "^7.0.0",
    "rehype-prism-plus": "^1.6.3",
    "rehype-slug": "^6.0.0",
    "remark-directive": "2.0.1",
    "remark-directive-rehype": "^0.4.2",
    "remark-gfm": "3.0.1",
    "remark-math": "5.1.1",
    "server-only": "^0.0.1",
    "sonner": "^1.4.41",
    "swr": "^2.2.5",
    "unist-util-visit": "^5.0.0",
    "use-immer": "^0.9.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/js": "^9.4.0",
    "@konghayao/cn-font-split": "^4.14.6",
    "@tailwindcss/typography": "^0.5.13",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.14.1",
