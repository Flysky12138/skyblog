    "framer-motion": "9.0.2",
    "immer": "^10.1.1",
    "jszip": "^3.10.1",
    "monaco-editor": "0.50.0",
    "next": "^14.2.5",
    "next-auth": "5.0.0-beta.5",
    "next-mdx-remote": "^5.0.0",
    "nextjs-toploader": "^1.6.12",
    "puppeteer-core": "22.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-photo-view": "^1.2.6",
    "react-use": "^17.5.1",
    "react-window": "^1.8.10",
    "rehype-katex": "^7.0.0",
    "rehype-pretty-code": "^0.13.2",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^3.0.0",
